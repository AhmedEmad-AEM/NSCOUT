fit_text() {
    local text="$1"
    local width="$2"

    if [ "${#text}" -gt "$width" ]; then
        printf "%s..." "${text:0:$((width - 3))}"
    else
        printf "%s" "$text"
    fi
}

print_menu() {
    local target_text status_text

    target_text="$(fit_text "${TARGET:-not set}" 51)"
    status_text="$(fit_text "$ACTION_STATUS" 51)"

    clear_screen
    print_logo
    printf "\n"
    printf "%s\n" "+-------------------------------------------------------------+"
    printf "| Target : %-51s|\n" "$target_text"
    printf "| Status : %-51s|\n" "$status_text"
    printf "%s\n" "+-------------------------------------------------------------+"
    printf "| %-58s  |\n" "1)  Set target network or host"
    printf "| %-58s  |\n" "2)  Discover live devices"
    printf "| %-58s  |\n" "3)  Local ARP discovery"
    printf "| %-58s  |\n" "4)  DNS/list scan"
    printf "| %-58s  |\n" "5)  Quick scan"
    printf "| %-58s  |\n" "6)  Common services scan"
    printf "| %-58s  |\n" "7)  All TCP ports scan"
    printf "| %-58s  |\n" "8)  All TCP and UDP ports scan"
    printf "| %-58s  |\n" "9)  Service/version detection"
    printf "| %-58s  |\n" "10) OS detection and traceroute"
    printf "| %-58s  |\n" "11) UDP top ports scan"
    printf "| %-58s  |\n" "12) IPv6 scan mode"
    printf "| %-58s  |\n" "13) Full inventory"
    printf "| %-58s  |\n" "14) Deep inventory"
    printf "| %-58s  |\n" "15) Show discovered hosts"
    printf "| %-58s  |\n" "0)  Exit"
    printf "%s\n" "+-------------------------------------------------------------+"
}

show_help() {
    cat <<EOF
$PROG_NAME Help

Usage:
  ./nscout.sh [target]
  ./nscout.sh --help

Run without arguments to open the scanner menu.

Examples:
  ./nscout.sh
  ./nscout.sh 192.168.1.0/24
  ./nscout.sh 10.10.10.5

Notes:
  Full TCP and UDP scans can be slow. Use them only on networks you are allowed to test.
EOF
}

parse_args() {
    local arg

    for arg in "$@"; do
        case "$arg" in
            -h|--help)
                show_help
                exit 0
                ;;
            *)
                TARGET="$arg"
                ;;
        esac
    done
}

main_menu() {
    local choice

    while true; do
        print_menu
        printf "Choose an option: "
        read -r choice

        case "$choice" in
            1) set_target; pause ;;
            2) discover_live_hosts; pause ;;
            3) arp_discovery; pause ;;
            4) dns_list_scan; pause ;;
            5) quick_scan; pause ;;
            6) common_services_scan; pause ;;
            7) all_tcp_ports_scan; pause ;;
            8) all_tcp_udp_ports_scan; pause ;;
            9) service_version_scan; pause ;;
            10) os_traceroute_scan; pause ;;
            11) udp_top_ports_scan; pause ;;
            12) ipv6_scan; pause ;;
            13) full_inventory; pause ;;
            14) deep_inventory; pause ;;
            15) show_discovered_hosts; pause ;;
            0|q|Q)
                printf "Goodbye.\n"
                exit 0
                ;;
            *)
                err "Invalid option."
                pause
                ;;
        esac
    done
}

main() {
    parse_args "$@"
    ensure_session_dir
    trap cleanup_runtime EXIT
    check_nmap
    main_menu
}

main "$@"
